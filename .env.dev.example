APP_NAME="All-In American School"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# DATABASE
# Opción A — PostgreSQL local (recomendado, igual a producción)
# ============================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=american_school_dev
DB_USERNAME=postgres
DB_PASSWORD=secret

# ============================================
# DATABASE
# Opción B — SQLite (más sencillo, sin instalar PostgreSQL)
# Descomenta estas líneas y comenta las de Opción A
# ============================================
# DB_CONNECTION=sqlite
# DB_DATABASE=/ruta/absoluta/al/proyecto/database/database.sqlite

# ============================================
# FRONTEND — URL del frontend en desarrollo
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# SANCTUM — Dominios del SPA frontend
# ============================================
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# ============================================
# SESSION
# ============================================
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ============================================
# MAIL — Resend SMTP
# Obtén tu API key en: https://resend.com
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=2525
MAIL_USERNAME=resend
MAIL_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="${APP_NAME}"

# Email donde se reciben las notificaciones de nuevos leads
NOTIFICATION_EMAIL=tu-correo@gmail.com
