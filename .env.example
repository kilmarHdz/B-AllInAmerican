APP_NAME="All-In American School"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-dominio-vps.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ============================================
# DATABASE — PostgreSQL en VPS
# ============================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=american_school
DB_USERNAME=tu_usuario_db
DB_PASSWORD=tu_password_seguro

# ============================================
# FRONTEND — URL de Vercel
# Soporta múltiples URLs separadas por coma
# ============================================
FRONTEND_URL=https://tu-app.vercel.app

# ============================================
# SANCTUM — Dominios del SPA frontend
# Agregar el dominio de Vercel (sin https://)
# ============================================
SANCTUM_STATEFUL_DOMAINS=tu-app.vercel.app

# ============================================
# SESSION — Configuración para producción
# ============================================
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ============================================
# MAIL — Gmail SMTP
# ============================================
# 1. Activa verificación en 2 pasos: https://myaccount.google.com/signinoptions/two-step-verification
# 2. Genera una App Password: https://myaccount.google.com/apppasswords
# 3. Pega la contraseña de 16 caracteres (sin espacios) en MAIL_PASSWORD
# ============================================
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-correo@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_FROM_ADDRESS="tu-correo@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# Email donde se reciben las notificaciones de nuevos leads
NOTIFICATION_EMAIL=tu-correo@gmail.com

# ============================================
# Sail Docker user mapping (solo dev)
# ============================================
# WWWUSER=1000
# WWWGROUP=1000
